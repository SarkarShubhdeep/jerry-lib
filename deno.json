{
  "name": "@sarkarshubhdeep/jerry-lib",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "tasks": {
    "test": "deno test --allow-read --allow-write src/",
    "check": "deno check mod.ts examples/minimal.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "publish": {
    "exclude": ["examples/", "**/*_test.ts", ".github/"]
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.ns"]
  },
  "imports": {
    "openai": "npm:openai@^6.41.0",
    "a3t": "./vendor/a3t/mod.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/", "mod.ts", "examples/"]
  },
  "lint": {
    "include": ["src/", "mod.ts", "examples/"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
