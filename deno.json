{
  "name": "@sarkarshubhdeep/jerry-lib",
  "version": "0.2.0",
  "exports": "./mod.ts",
  "tasks": {
    "test": "deno test --allow-read --allow-write --allow-net --allow-env src/ mod_test.ts",
    "test:coverage": "deno test --allow-read --allow-write --allow-net --allow-env --coverage=.coverage src/ mod_test.ts && deno coverage .coverage",
    "bench": "deno bench --allow-read src/",
    "check": "deno check mod.ts examples/minimal.ts examples/report-pipeline.ts mod_test.ts",
    "check:docs": "deno run --allow-read scripts/check-docs.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "smoke": "deno run --allow-read examples/external-smoke/local-smoke.ts"
  },
  "publish": {
    "exclude": ["examples/", "docs/", "**/*_test.ts", "**/*_bench.ts", "mod_test.ts", ".github/"]
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window", "deno.ns"]
  },
  "imports": {
    "openai": "npm:openai@^6.41.0",
    "a3t": "./vendor/a3t/mod.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/", "mod.ts", "examples/"]
  },
  "lint": {
    "include": ["src/", "mod.ts", "examples/"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
